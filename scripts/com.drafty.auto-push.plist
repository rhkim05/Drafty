<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.drafty.auto-push</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>DRAFTY_PATH_PLACEHOLDER/scripts/git-auto-push.sh</string>
    </array>
    <key>StartInterval</key>
    <integer>300</integer>
    <key>RunAtLoad</key>
    <true/>
    <key>StandardErrorPath</key>
    <string>DRAFTY_PATH_PLACEHOLDER/scripts/auto-push-error.log</string>
</dict>
</plist>
